#!/usr/bin/env python3
"""
gemini-estimate — Macro estimation via Gemini (thin wrapper around fuel_cli.gemini).

Usage:
  gemini-estimate "250g Basmati Reis"

Output: {"kcal": …, "protein": …, "carbs": …, "fat": …}

Note: Uses the unified fuel_cli.gemini.estimate_nutrition() under the hood,
but extracts only the macros for backward compatibility with server.mjs.
For full breakdown (macros + micros + components) use `gemini-nutrition`.
"""

from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from fuel_cli.gemini import estimate_macros_only


def main() -> int:
    if len(sys.argv) < 2:
        print(json.dumps({"error": "Usage: gemini-estimate 'meal description'"}), file=sys.stderr)
        return 1
    description = sys.argv[1]
    result = estimate_macros_only(description)
    print(json.dumps(result, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    sys.exit(main())
