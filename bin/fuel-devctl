#!/usr/bin/env python3
"""
fuel-devctl — Python-powered Fuel Centre Stack Control
Replaces the legacy bash script with a more robust and stylish version.
"""

import os
import signal
import subprocess
import sys
import time
from pathlib import Path
from typing import Optional

import typer
from wasabi import Printer

msg = Printer()

app = typer.Typer(help="Fuel Centre Stack Control (Python Edition)", no_args_is_help=True)

# ── Config ────────────────────────────────────────────────────────────────────

PORT = os.getenv("PORT", "9000")
HEALTH_URL = f"http://127.0.0.1:{PORT}/health"
DEV_DIR = Path(__file__).resolve().parent.parent
LOGFILE = Path("/tmp/fuelctx-dev.log")
PIDFILE = Path("/tmp/fuelctx-dev.pid")

# ── Helpers ───────────────────────────────────────────────────────────────────

def gum_log(level: str, text: str):
    """Wrapper for gum log if available."""
    try:
        subprocess.run(["gum", "log", f"--level={level}", text])
    except:
        # Fallback to wasabi if gum fails
        if level == "info": msg.info(text)
        elif level == "warn": msg.warn(text)
        elif level == "error": msg.fail(text)

def get_pid() -> Optional[int]:
    if PIDFILE.exists():
        try:
            return int(PIDFILE.read_text().strip())
        except ValueError:
            return None
    return None

def is_running() -> bool:
    import urllib.request
    try:
        with urllib.request.urlopen(HEALTH_URL, timeout=1):
            return True
    except:
        return False

# ── Commands ──────────────────────────────────────────────────────────────────

@app.command()
def status():
    """Check the status of the Fuel stack."""
    msg.divider("System Status")
    if is_running():
        pid = get_pid()
        msg.good(f"Fuel Stack is online on port {PORT}")
        if pid:
            msg.info(f"Main Process PID: {pid}")
    else:
        msg.warn(f"Stack is not responding on port {PORT}")

@app.command()
def start():
    """Start the Fuel stack in the background."""
    if is_running():
        msg.warn(f"Stack is already running on port {PORT}")
        return

    os.chdir(DEV_DIR)
    
    # Ensure logfile is fresh
    try:
        LOGFILE.touch()
        with open(LOGFILE, "w") as f:
            f.truncate(0)
    except Exception as e:
        msg.fail(f"Could not prepare logfile {LOGFILE}: {e}")
        raise typer.Exit(1)

    gum_log("info", f"Starting stack in background (Logs: {LOGFILE})...")
    
    # Using start_new_session=True to detach from this terminal
    proc = subprocess.Popen(
        ["npm", "run", "dev"],
        stdout=open(LOGFILE, "a"),
        stderr=subprocess.STDOUT,
        cwd=DEV_DIR,
        start_new_session=True
    )
    
    PIDFILE.write_text(str(proc.pid))
    
    # Wait for startup
    msg.info("Waiting for service to become healthy...")
    for i in range(15):
        time.sleep(1)
        if is_running():
            msg.good("Stack is now online and healthy!")
            return
        if i % 5 == 0 and i > 0:
            msg.info(f"Still waiting ({i}s)...")

    msg.fail("Stack failed to start within 15 seconds. Please check logs.")
    msg.info(f"Command: tail -n 20 {LOGFILE}")

@app.command()
def stop():
    """Stop the Fuel stack and all related processes."""
    pid = get_pid()
    
    if pid:
        gum_log("warn", f"Terminating process group for PID {pid}...")
        try:
            os.killpg(os.getpgid(pid), signal.SIGTERM)
            time.sleep(1)
            # Check if still alive
            if os.path.exists(f"/proc/{pid}"):
                os.killpg(os.getpgid(pid), signal.SIGKILL)
        except ProcessLookupError:
            pass
        except Exception as e:
            msg.warn(f"Error while killing process group: {e}")

    # Aggressive cleanup of Node/Vite leftovers
    msg.info("Cleaning up leftover Node.js and Vite processes...")
    subprocess.run(
        ["pkill", "-f", "node.*scripts/dev-runner.mjs|nodemon.*scripts/dev-runner.mjs|node.*server.mjs|node_modules/.bin/vite|vite"],
        stderr=subprocess.DEVNULL
    )
    
    if PIDFILE.exists():
        PIDFILE.unlink()
        
    msg.good("Fuel Stack stopped.")

@app.command()
def restart():
    """Stop and then start the Fuel stack."""
    stop()
    time.sleep(1)
    start()

@app.command()
def logs(n: int = typer.Option(50, "--lines", "-n", help="Number of lines to show initially")):
    """Tail the stack logs."""
    if not LOGFILE.exists():
        msg.fail(f"Log file not found at {LOGFILE}")
        return

    msg.divider("Log Stream (Ctrl+C to stop)")
    try:
        subprocess.run(["tail", f"-n{n}", "-f", str(LOGFILE)])
    except KeyboardInterrupt:
        print("\n")
        msg.info("Stopped tailing logs.")

@app.command()
def build():
    """Run the production build for the UI."""
    msg.info("Running UI build...")
    subprocess.run(["npm", "run", "build"], cwd=DEV_DIR)

@app.command()
def dev():
    """Run the stack in the foreground (for debugging)."""
    msg.divider("Foreground Mode")
    try:
        subprocess.run(["npm", "run", "dev"], cwd=DEV_DIR)
    except KeyboardInterrupt:
        print("\n")
        msg.info("Foreground process stopped by user.")

if __name__ == "__main__":
    app()
