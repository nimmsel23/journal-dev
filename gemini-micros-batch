#!/usr/bin/env python3
"""
gemini-micros-batch — Mikronährstoffe für alle geloggten Mahlzeiten via Gemini schätzen
und in SQLite (meal_micros) speichern.

Usage:
  gemini-micros-batch              # alle Logs
  gemini-micros-batch --dry-run    # nur zeigen was geschätzt würde
  gemini-micros-batch --force      # auch bereits vorhandene Einträge neu schätzen
"""

from __future__ import annotations

import json
import os
import sqlite3
import sys
import time
from pathlib import Path

# ── Env ───────────────────────────────────────────────────────────────────────

def _load_env(path: Path) -> None:
    if path.exists():
        for line in path.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                k, sep, v = line.partition("=")
                if sep:
                    os.environ[k.strip()] = v.strip()

_load_env(Path.home() / ".env" / "fuel.env")

# ── Config ────────────────────────────────────────────────────────────────────

GEMINI_API_KEY  = os.environ.get("GEMINI_API_KEY", "")
GEMINI_MODEL    = os.environ.get("GEMINI_MODEL", "gemini-2.5-flash")
GEMINI_API_URL  = f"https://generativelanguage.googleapis.com/v1beta/models/{GEMINI_MODEL}:generateContent"
NUTRITION_DIR   = Path.home() / ".aos" / "fuel" / "nutrition"
DB_PATH         = NUTRITION_DIR / "nutrition.db"

MICRO_KEYS = [
    "vitamin_a_ug", "vitamin_d_ug", "vitamin_e_mg", "vitamin_k_ug",
    "vitamin_c_mg", "vitamin_b1_mg", "vitamin_b2_mg", "vitamin_b3_mg",
    "vitamin_b5_mg", "vitamin_b6_mg", "vitamin_b7_ug", "folate_ug", "vitamin_b12_ug",
    "calcium_mg", "phosphorus_mg", "magnesium_mg", "iron_mg", "zinc_mg",
    "selenium_ug", "iodine_ug", "potassium_mg", "sodium_mg", "omega3_mg",
]

# ── SQLite ────────────────────────────────────────────────────────────────────

def get_existing(db: sqlite3.Connection) -> set[str]:
    return {r[0].lower() for r in db.execute("SELECT meal_name FROM meal_micros").fetchall()}

def upsert(db: sqlite3.Connection, meal_name: str, micros: dict) -> None:
    cols = ", ".join(MICRO_KEYS)
    placeholders = ", ".join("?" * len(MICRO_KEYS))
    sets = ", ".join(f"{k} = excluded.{k}" for k in MICRO_KEYS)
    vals = [micros.get(k, 0) for k in MICRO_KEYS]
    db.execute(f"""
        INSERT INTO meal_micros (meal_name, {cols}, source)
        VALUES (?, {placeholders}, 'gemini')
        ON CONFLICT(meal_name) DO UPDATE SET {sets},
            source = excluded.source,
            updated_at = CURRENT_TIMESTAMP
    """, [meal_name, *vals])
    db.commit()

# ── Gemini ────────────────────────────────────────────────────────────────────

import urllib.request

def call_gemini(description: str) -> dict | None:
    if not GEMINI_API_KEY:
        print("  ✗ GEMINI_API_KEY fehlt", file=sys.stderr)
        return None

    prompt = f"""Schätze die Mikronährstoffe für diese Mahlzeit:
"{description}"

Antworte NUR mit JSON (keine Erklärungen):
{{
  "vitamin_a_ug": <Wert>, "vitamin_d_ug": <Wert>, "vitamin_e_mg": <Wert>, "vitamin_k_ug": <Wert>,
  "vitamin_c_mg": <Wert>, "vitamin_b1_mg": <Wert>, "vitamin_b2_mg": <Wert>, "vitamin_b3_mg": <Wert>,
  "vitamin_b5_mg": <Wert>, "vitamin_b6_mg": <Wert>, "vitamin_b7_ug": <Wert>, "folate_ug": <Wert>,
  "vitamin_b12_ug": <Wert>, "calcium_mg": <Wert>, "phosphorus_mg": <Wert>, "magnesium_mg": <Wert>,
  "iron_mg": <Wert>, "zinc_mg": <Wert>, "selenium_ug": <Wert>, "iodine_ug": <Wert>,
  "potassium_mg": <Wert>, "sodium_mg": <Wert>, "omega3_mg": <Wert>
}}"""

    try:
        payload = json.dumps({"contents": [{"parts": [{"text": prompt}]}]}, ensure_ascii=False).encode()
        req = urllib.request.Request(
            GEMINI_API_URL,
            data=payload,
            headers={"Content-Type": "application/json", "X-goog-api-key": GEMINI_API_KEY},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=20) as resp:
            result = json.loads(resp.read())
        text = result["candidates"][0]["content"]["parts"][0]["text"].strip()
        # Strip markdown code fences if present
        if text.startswith("```"):
            text = text.split("```")[1]
            if text.startswith("json"):
                text = text[4:]
        micros = json.loads(text)
        if isinstance(micros, dict) and len(set(MICRO_KEYS) & micros.keys()) >= 20:
            return micros
    except Exception as e:
        print(f"  ✗ Gemini Fehler: {e}", file=sys.stderr)
    return None

# ── Collect meals ─────────────────────────────────────────────────────────────

def collect_meals() -> list[str]:
    seen: set[str] = set()
    meals: list[str] = []
    for log_file in sorted(NUTRITION_DIR.glob("????-??-??.json")):
        try:
            data = json.loads(log_file.read_text())
        except Exception:
            continue
        for meal in data.get("meals", []):
            desc = (meal.get("description") or "").strip()
            if desc and desc.lower() not in seen:
                seen.add(desc.lower())
                meals.append(desc)
    return meals

# ── Main ──────────────────────────────────────────────────────────────────────

def main() -> None:
    dry_run = "--dry-run" in sys.argv
    force   = "--force"   in sys.argv

    meals = collect_meals()
    print(f"Gefundene einzigartige Mahlzeiten: {len(meals)}")

    if dry_run:
        for m in meals:
            print(f"  · {m}")
        return

    db = sqlite3.connect(DB_PATH)
    existing = get_existing(db)

    to_process = [m for m in meals if force or m.lower() not in existing]
    skip_count = len(meals) - len(to_process)

    print(f"Übersprungen (bereits in DB): {skip_count}")
    print(f"Zu schätzen: {len(to_process)}\n")

    for i, meal in enumerate(to_process, 1):
        print(f"[{i}/{len(to_process)}] {meal}")
        micros = call_gemini(meal)
        if micros:
            upsert(db, meal, micros)
            print(f"  ✓ gespeichert")
        else:
            print(f"  ✗ übersprungen")
        if i < len(to_process):
            time.sleep(1.5)  # Rate-Limit schonen

    db.close()
    print(f"\nFertig.")

if __name__ == "__main__":
    main()
