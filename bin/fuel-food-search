#!/usr/bin/env python3
"""
fuel-food-search — Lebensmittel über Open Food Facts (OFF) suchen und Makros skalieren.
Replaces the legacy wger-food bash script.
"""

import json
import os
import subprocess
import sys
import urllib.request
import urllib.parse
from pathlib import Path
from datetime import date, datetime

import typer
from wasabi import Printer
from rich.console import Console
from rich.table import Table

msg = Printer()
console = Console()
app = typer.Typer(help="Search and log food from Open Food Facts", no_args_is_help=False)

# ── Config ────────────────────────────────────────────────────────────────────

OFF_URL = "https://world.openfoodfacts.org/cgi/search.pl"
LIMIT = 30
MEAL_DEFAULT = "Vormittag"
WGER_LOG = Path(os.environ.get("WGER_LOG", Path.home() / "Nutrition" / "logs" / f"{date.today().isoformat()}.md"))

# ── Helpers ───────────────────────────────────────────────────────────────────

def copy_to_clipboard(text: str):
    try:
        if subprocess.run(["which", "wl-copy"], capture_output=True).returncode == 0:
            subprocess.run(["wl-copy"], input=text.encode())
            msg.info("In Zwischenablage (wl-copy)")
        elif subprocess.run(["which", "xclip"], capture_output=True).returncode == 0:
            subprocess.run(["xclip", "-selection", "clipboard"], input=text.encode())
            msg.info("In Zwischenablage (xclip)")
    except:
        pass

def search_off(query: str):
    params = {
        "search_terms": query,
        "search_simple": 1,
        "action": "process",
        "json": 1,
        "page_size": LIMIT
    }
    url = f"{OFF_URL}?{urllib.parse.urlencode(params)}"
    
    headers = {"User-Agent": "fuel-food-search/1.0 (nutrition log)"}
    req = urllib.request.Request(url, headers=headers)
    
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except Exception as e:
        msg.fail(f"OFF API Fehler: {e}")
        return None

# ── Logic ─────────────────────────────────────────────────────────────────────

@app.command()
def search(query: str = typer.Argument(None)):
    """Search for food items on Open Food Facts."""
    if not query:
        query = typer.prompt("Lebensmittel suchen")
    
    msg.info(f"Suche nach '{query}'...")
    data = search_off(query)
    
    if not data or data.get("count", 0) == 0:
        msg.fail(f"Keine Treffer für: {query}")
        return

    products = []
    for p in data.get("products", []):
        name = p.get("product_name", "")
        brand = p.get("brands", "-")
        nutriments = p.get("nutriments", {})
        kcal = nutriments.get("energy-kcal_100g") or nutriments.get("energy_100g", 0) / 4.184
        
        if name and kcal:
            products.append({
                "name": name,
                "brand": brand,
                "kcal100": float(kcal),
                "kh100": float(nutriments.get("carbohydrates_100g", 0)),
                "fat100": float(nutriments.get("fat_100g", 0)),
                "protein100": float(nutriments.get("proteins_100g", 0))
            })

    if not products:
        msg.fail("Keine nutzbaren Daten gefunden.")
        return

    # FZF selection
    fzf_input = ""
    for i, p in enumerate(products):
        fzf_input += f"{i}\t{p['name'][:40]}\t{p['brand'][:20]}\t{p['kcal100']:.1f} kcal\t{p['kh100']:.1f} KH\n"

    try:
        res = subprocess.run(
            ["fzf", "--delimiter", "\t", "--with-nth", "2,3,4,5", "--header", "AUSWÄHLEN (Enter)", "--reverse"],
            input=fzf_input, capture_output=True, text=True
        )
        if res.returncode != 0: return
        
        idx = int(res.stdout.split("\t")[0])
        p = products[idx]
        
        msg.divider(p['name'])
        
        # Portion size
        console.print("[bold]Portionsgröße:[/bold]")
        console.print("  [s] Klein     ~100g")
        console.print("  [m] Normal    ~200g")
        console.print("  [l] Groß      ~300g")
        console.print("  [x] Sehr groß ~450g")
        console.print("  [g] Gramm eingeben")
        
        choice = typer.prompt("Wahl", default="m")
        grams = 200
        if choice.lower() == 's': grams = 100
        elif choice.lower() == 'm': grams = 200
        elif choice.lower() == 'l': grams = 300
        elif choice.lower() == 'x': grams = 450
        elif choice.lower() == 'g' or choice.isdigit():
            grams = int(choice) if choice.isdigit() else int(typer.prompt("Menge in g"))
            
        meal = typer.prompt("Mahlzeit", default=MEAL_DEFAULT)
        
        factor = grams / 100.0
        kcal = p['kcal100'] * factor
        kh = p['kh100'] * factor
        fat = p['fat100'] * factor
        protein = p['protein100'] * factor
        
        now = datetime.now().strftime("%H:%M")
        food_full = f"{p['name']} ({p['brand']})" if p['brand'] != "-" else p['name']
        
        line = f"| {meal} | {now} | {food_full} | {grams} | g | {kcal:.1f} | {kh:.1f} | {fat:.1f} | {protein:.1f} | Open Food Facts |"
        
        msg.info("Markdown Zeile:")
        console.print(line)
        
        # Save to file
        WGER_LOG.parent.mkdir(parents=True, exist_ok=True)
        if not WGER_LOG.exists():
            WGER_LOG.write_text("| Mahlzeit | Uhrzeit | Lebensmittel / Getränk | Menge | Einheit | Kcal | KH (g) | Fett (g) | Eiweiß (g) | Quelle |\n"
                               "|----------|---------|------------------------|-------|---------|------|--------|----------|------------|--------|\n")
        
        with open(WGER_LOG, "a") as f:
            f.write(line + "\n")
            
        msg.good(f"Gespeichert in {WGER_LOG}")
        copy_to_clipboard(line)

    except Exception as e:
        msg.fail(f"Fehler: {e}")

if __name__ == "__main__":
    app()
