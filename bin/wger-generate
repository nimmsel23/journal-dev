        ("Kidneybohnen",           200, 127, 20.0,  0.5,  8.7),
        ("Hühnerbrust (gegrillt)", 180, 110,  0.0,  1.2, 24.0),
        ("Paprika (roh)",          150,  31,  6.0,  0.3,  1.0),
        ("Olivenöl",               20, 884,  0.0, 100.0, 0.0),
        ("Vollkornbrot",           60, 220, 38.0,  2.5,  8.0),
    ],
]

ZEITEN = {
    "Vormittag": ["07:00","07:15","07:30","08:00","08:15","08:30"],
    "Nachmittag": ["12:00","12:15","12:30","13:00","13:15"],
    "Abend":     ["18:30","19:00","19:15","19:30","20:00"],
}


def calc(food, variation=1.0):
    name, g_base, kcal100, kh100, fett100, ew100 = food
    g = max(10, round(g_base * variation / 10) * 10)
    f = g / 100
    return {
        "name":  name,
        "menge": g,
        "kcal":  round(kcal100 * f, 1),
        "kh":    round(kh100 * f, 1),
        "fett":  round(fett100 * f, 1),
        "ew":    round(ew100 * f, 1),
    }


def make_row(mahlzeit, uhrzeit, item):
    return (
        f"| {mahlzeit} | {uhrzeit} | {item['name']} | {item['menge']} | g | "
        f"{item['kcal']} | {item['kh']} | {item['fett']} | {item['ew']} | Schätzwert |\n"
    )


def generate_day(tag_date):
    rng = random.Random(tag_date.toordinal() + 42)
    v = rng.uniform(0.90, 1.10)  # leichte Mengen-Variation pro Tag

    frueh_kombi  = rng.choice(FRUEHSTUECK)
    mittag_kombi = rng.choice(MITTAGESSEN)
    abend_kombi  = rng.choice(ABENDESSEN)

    rows = []
    for mahlzeit, kombi in [("Vormittag", frueh_kombi),
                              ("Nachmittag", mittag_kombi),
                              ("Abend", abend_kombi)]:
        uhrzeit = rng.choice(ZEITEN[mahlzeit])
        for food in kombi:
            item = calc(food, v)
            rows.append(make_row(mahlzeit, uhrzeit, item))

    return rows


def write_day(tag_date, rows, preview):
    total_kcal = sum(float(r.split("|")[6].strip()) for r in rows)
    total_kh   = sum(float(r.split("|")[7].strip()) for r in rows)
    total_fett = sum(float(r.split("|")[8].strip()) for r in rows)
    total_ew   = sum(float(r.split("|")[9].strip()) for r in rows)
    sumrow = (
        f"| **Tagesgesamt** | | | | | **{total_kcal:.0f}** | "
        f"**{total_kh:.0f}** | **{total_fett:.0f}** | **{total_ew:.0f}** | |\n"
    )

    date_str = tag_date.strftime("%d.%m.%Y")
    log_path = LOG_DIR / f"{tag_date.isoformat()}.md"

    if preview:
        print(f"\n## {date_str}  ({total_kcal:.0f} kcal)\n")
        print(HEADER + DIVIDER + "".join(rows) + sumrow)
        return

    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log_path.write_text(HEADER + DIVIDER + "".join(rows) + sumrow)
    print(f"  {date_str}  →  {total_kcal:.0f} kcal  →  {log_path.name}")


def main():
    parser = argparse.ArgumentParser(description="Ernährungsprotokoll-Generator")
    parser.add_argument("--days",    type=int, default=14)
    parser.add_argument("--start",   type=str, default=None)
    parser.add_argument("--preview", action="store_true")
    args = parser.parse_args()

    start = date.fromisoformat(args.start) if args.start else date.today()
    print(f"\nGeneriere {args.days}-Tage-Protokoll ab {start.strftime('%d.%m.%Y')}\n")

    for i in range(args.days):
        tag = start + timedelta(days=i)
        rows = generate_day(tag)
        write_day(tag, rows, args.preview)

    if not args.preview:
        print(f"\nFertig → {LOG_DIR}/")


if __name__ == "__main__":
    main()
