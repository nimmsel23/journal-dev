#!/usr/bin/env python3
"""
gemini-discovery — Classify input as Supplement or Meal, return full catalog entry.

Usage:
  gemini-discovery "Magnesium Citrat 400mg"
  gemini-discovery "Wiener Schnitzel mit Pommes"

Output: JSON {type: "supplement"|"meal", catalog_entry: {…}} oder {error: …}.
"""

from __future__ import annotations

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from fuel_cli.gemini import discover_item


def main() -> int:
    if len(sys.argv) < 2:
        print(json.dumps({"error": "Usage: gemini-discovery 'query'"}), file=sys.stderr)
        return 1
    query = sys.argv[1]
    print(json.dumps(discover_item(query), ensure_ascii=False))
    return 0


if __name__ == "__main__":
    sys.exit(main())
