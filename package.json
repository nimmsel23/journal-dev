{
  "name": "@vos/journal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/db.js",
    "./views": "./src/views/JournalVosView.jsx",
    "./lib/db": "./src/lib/db/journal.js",
    "./lib/habits": "./src/lib/db/habits.js",
    "./lib/user": "./src/lib/db/user.js",
    "./lib/utils": "./src/lib/db/utils.js"
  },
  "description": "Journal VOS — Journal + Habit PWA auf fuel-dev Shell (Firestore via fitness-aos)",
  "scripts": {
    "dev": "VITE_APP_MODE=client vite --config vite.config.cjs",
    "build": "VITE_APP_MODE=client vite build --config vite.config.cjs",
    "preview": "vite preview --config vite.config.cjs",
    "build:firebase": "VITE_APP_MODE=client vite build --mode firebase --config vite.config.cjs && npm run bump:sw",
    "build:cloud": "VITE_APP_MODE=client vite build --mode firebase --config vite.config.cjs && npm run bump:sw",
    "deploy": "npm run build:cloud && firebase deploy --only hosting --project fitness-aos",
    "deploy:cloud": "npm run build:cloud && firebase deploy --only hosting --project fitness-aos",
    "deploy:preview": "npm run build:cloud && firebase hosting:channel:deploy preview --expires 24h --project fitness-aos",
    "release": "npm version patch --no-git-tag-version && npm run deploy:cloud",
    "bump:sw": "node scripts/bump-sw.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "fastify": "^4.28.1",
    "firebase": "^11.0.1",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.3",
    "yaml": "^2.9.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
