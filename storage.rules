rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Journal media: Benutzer können nur ihre eigenen Fotos hochladen/lesen
    match /journal/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Alles andere: blocked
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
