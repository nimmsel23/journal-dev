# ── Weekly Report (Pandas) ─────────────────────────────────────────────────────

def do_weekly_report(day: str | None = None) -> None:
    """Generate weekly report with pandas and export to CSV."""
    today = day or date.today().isoformat()
    target_date = date.fromisoformat(today)

    # Get ISO week info
    iso = target_date.isocalendar()
    week_key = f"{iso.year}-W{iso.week:02d}"

    # Calculate week start (Monday)
    jan4 = date(iso.year, 1, 4)
    week_monday = jan4 - timedelta(days=jan4.weekday())
    week_monday += timedelta(weeks=iso.week - 1)

    # Collect all intakes for the week
    rows = []
    for i in range(7):
        day_date = week_monday + timedelta(days=i)
        day_str = day_date.isoformat()
        data = read_log(day_str)

        for intake in data.get("intakes", []):
            rows.append({
                "date": day_str,
                "day": day_date.strftime("%a"),
                "supplement": intake.get("name", ""),
                "dose": intake.get("dose", 0),
                "unit": intake.get("unit", ""),
                "time_of_day": intake.get("time_of_day", "any"),
                "notes": intake.get("notes", ""),
            })

    if not rows:
        gum_log("warn", f"Keine Supplements für Woche {week_key} geloggt")
        return

    # Create DataFrame and aggregate
    df = pd.DataFrame(rows)
    df["dose"] = pd.to_numeric(df["dose"], errors="coerce").fillna(0)

    # Summary by supplement (total dose per week)
    summary = df.groupby("supplement").agg({
        "dose": "sum",
        "unit": "first",
        "date": "count",
    }).rename(columns={"date": "count"}).round(2)

    # Export to CSV
    csv_file = FUEL_DIR / f"fuel_weekly_{week_key}.csv"
    df.to_csv(csv_file, index=False, encoding="utf-8")
    gum_log("info", f"CSV exportiert: {csv_file}")

    # Display summary with rich Table
    week_start = week_monday.isoformat()
    week_end = (week_monday + timedelta(days=6)).isoformat()
    console.print(f"[bold magenta]Fuel Weekly Report — {week_key}[/bold magenta] [dim]Mo {week_start} — So {week_end}[/dim]")

    table = Table(show_header=True, header_style="bold magenta")
    table.add_column("SUPPLEMENT", style="green")
    table.add_column("TOTAL DOSE", style="cyan")
    table.add_column("UNIT", style="yellow")
    table.add_column("COUNT", style="blue")

    for supplement, row in summary.iterrows():
        table.add_row(
            supplement,
            str(row["dose"]),
            row["unit"],
            str(int(row["count"]))
        )

    console.print(table)
    console.print(f"[dim]CSV: {csv_file}[/dim]")

def _main() -> None:
    catalog = load_catalog()

    # Shortcut: fuel meal [optional args]
    if len(sys.argv) >= 2 and sys.argv[1] == "meal":
        # Interactive mode if no description given
        if len(sys.argv) == 2:
            do_meal_interactive()
            return

        # Parse meal arguments
        description = None
        kcal = 0
        protein = 0
        carbs = 0
        fat = 0
        notes = ""
        day = None
        save_catalog = False

        args = sys.argv[2:]
        i = 0
        while i < len(args):
            if args[i] in ("--kcal",):
                kcal = float(args[i + 1]) if i + 1 < len(args) else 0
                i += 2
            elif args[i] in ("--protein",):
                protein = float(args[i + 1]) if i + 1 < len(args) else 0
                i += 2
            elif args[i] in ("--carbs",):
                carbs = float(args[i + 1]) if i + 1 < len(args) else 0
                i += 2
            elif args[i] in ("--fat",):
                fat = float(args[i + 1]) if i + 1 < len(args) else 0
                i += 2
            elif args[i] in ("--notes", "-n"):
                notes = args[i + 1] if i + 1 < len(args) else ""
                i += 2
            elif args[i] in ("--day", "-d"):
                day = args[i + 1] if i + 1 < len(args) else None
                i += 2
            elif args[i] in ("--save-catalog", "-s"):
                save_catalog = True
                i += 1
            elif not args[i].startswith("--") and not description:
                description = args[i]
                i += 1
            else:
                i += 1

        if description:
            do_meal_log(description, kcal, protein, carbs, fat, notes, day, save_catalog)
        else:
            gum_log("error", "Keine Mahlzeitbeschreibung gegeben")
            raise SystemExit(1)
        return

    # Shortcut: fuel zink [dose] [--time ...] [--day ...] [--yesterday] [--1d] etc.
    if len(sys.argv) >= 2 and sys.argv[1] in catalog:
        supplement = sys.argv[1]
        dose = None
        day = None
        time_of_day = None

        args = sys.argv[2:]
        i = 0
        while i < len(args):
            if args[i] in ("--day", "-d"):
                day = args[i + 1] if i + 1 < len(args) else None
                i += 2
            elif args[i] in ("--time", "-t"):
                time_of_day = args[i + 1] if i + 1 < len(args) else None
                i += 2
            elif args[i] == "--yesterday":
                day = (date.today() - timedelta(days=1)).isoformat()
                i += 1
            elif args[i].startswith("--") and args[i][2:].endswith("d") and args[i][2:-1].isdigit():
                # --1d, --2d, etc.
                days = int(args[i][2:-1])
                day = (date.today() - timedelta(days=days)).isoformat()
                i += 1
            elif _is_number(args[i]):
                dose = float(args[i])
                i += 1
            else:
                i += 1

        do_log(supplement, dose, time_of_day, day)
        return

    # Help with catalog
    if "--help" in sys.argv or "-h" in sys.argv:
        _print_help_with_catalog()
        return

    # Other commands: Typer
    app()

def _is_number(s: str) -> bool:
    try:
        float(s)
        return True
    except ValueError:
        return False

if __name__ == "__main__":
    _main()
